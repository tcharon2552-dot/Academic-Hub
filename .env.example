# PostgreSQL used by Prisma. The default matches docker-compose.yml.
DATABASE_URL="postgresql://academic_hub:academic_hub@localhost:5432/academic_hub"

# New API gateway used for real workflow calls outside E2E/demo tests.
NEW_API_BASE_URL="https://new-api.example.com"
NEW_API_KEY="replace-me"

# Public app origin used by payment/application links and future callbacks.
APP_BASE_URL="http://localhost:3000"

# Optional payment feature flag. Keep false for China-facing MVP launch.
ENABLE_CRYPTO_PAYMENTS="false"

# Playwright only. Do not set this in production.
# ACADEMIC_HUB_E2E_MODE="true"
